<Window x:Class="SabreALPR.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SabreALPR Mobile Monitor" Height="600" Width="1000" Background="#1a1a1a">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="2*" /> <RowDefinition Height="1*" /> <RowDefinition Height="1*" /> </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border BorderBrush="#333" BorderThickness="2" Margin="5">
                <Image Name="LiveVideoFeed" Stretch="Uniform" Source="https://via.placeholder.com/640x480?text=Live+VSR+Feed" />
            </Border>
            <Border Grid.Column="1" BorderBrush="#333" BorderThickness="2" Margin="5">
                <Image Name="ConfirmedPlateImage" Stretch="Uniform" />
            </Border>
        </Grid>

        <StackPanel Grid.Row="1" Background="#252525" Margin="5">
            <TextBlock Text="LAST CONFIRMED READ" HorizontalAlignment="Center" Foreground="Yellow" FontWeight="Bold"/>
            <UniformGrid Columns="3" Margin="10">
                <TextBlock Name="PlateText" Text="PLATE: --" Foreground="White" FontSize="20"/>
                <TextBlock Name="StateText" Text="STATE: --" Foreground="White" FontSize="20"/>
                <TextBlock Name="VehicleColor" Text="COLOR: --" Foreground="White" FontSize="20"/>
                <TextBlock Name="VehicleMake" Text="MAKE: --" Foreground="White" FontSize="20"/>
                <TextBlock Name="VehicleModel" Text="MODEL: --" Foreground="White" FontSize="20"/>
            </UniformGrid>
        </StackPanel>

        <DataGrid Grid.Row="2" Name="HistoryGrid" Background="#111" Foreground="White" 
                  AutoGenerateColumns="True" Margin="5" IsReadOnly="True" />
    </Grid>
</Window>